#!/command/with-contenv sh

instance_id="${PAPERCLIP_INSTANCE_ID:-default}"
paperclip_home="${PAPERCLIP_HOME:-/home/opencode/.paperclip}"
config_path="${paperclip_home}/instances/${instance_id}/config.json"
paperclip_host="${PAPERCLIP_HOST:-0.0.0.0}"
paperclip_port="${PAPERCLIP_PORT:-3100}"
paperclip_mode="${PAPERCLIP_DEPLOYMENT_MODE:-authenticated}"

if [ ! -f "$config_path" ]; then
  s6-setuidgid opencode env \
    HOST="$paperclip_host" \
    PORT="$paperclip_port" \
    PAPERCLIP_DEPLOYMENT_MODE="$paperclip_mode" \
    PAPERCLIP_HOME="$paperclip_home" \
    PAPERCLIP_INSTANCE_ID="$instance_id" \
    paperclipai onboard --yes --data-dir "$paperclip_home"
fi

s6-setuidgid opencode env \
  PAPERCLIP_CONFIG_PATH="$config_path" \
  PAPERCLIP_EFFECTIVE_HOST="$paperclip_host" \
  PAPERCLIP_EFFECTIVE_PORT="$paperclip_port" \
  PAPERCLIP_EFFECTIVE_MODE="$paperclip_mode" \
  python3 - <<'PY'
import json
import os

config_path = os.environ["PAPERCLIP_CONFIG_PATH"]
with open(config_path, "r", encoding="utf-8") as f:
    config = json.load(f)

server = config.setdefault("server", {})
server["deploymentMode"] = os.environ["PAPERCLIP_EFFECTIVE_MODE"]
server["exposure"] = server.get("exposure", "private")
server["host"] = os.environ["PAPERCLIP_EFFECTIVE_HOST"]
server["port"] = int(os.environ["PAPERCLIP_EFFECTIVE_PORT"])

auth = config.setdefault("auth", {})
auth["baseUrlMode"] = auth.get("baseUrlMode", "auto")

with open(config_path, "w", encoding="utf-8") as f:
    json.dump(config, f, indent=2)
    f.write("\n")
PY

exec s6-setuidgid opencode env \
  HOST="$paperclip_host" \
  PORT="$paperclip_port" \
  PAPERCLIP_DEPLOYMENT_MODE="$paperclip_mode" \
  PAPERCLIP_HOME="$paperclip_home" \
  PAPERCLIP_INSTANCE_ID="$instance_id" \
  paperclipai run --data-dir "$paperclip_home" --instance "$instance_id"
